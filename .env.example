# Copy to .env and fill in your values (see SETUP.txt)

# Your business name (used when the bot answers the phone)
BUSINESS_NAME=Bliss Events

# Public URL where this server is reachable (use ngrok for local dev)
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=https://your-domain.example.com

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional: validate incoming webhooks (recommended in production)
TWILIO_WEBHOOK_AUTH_TOKEN=

# Google Sheets — create a service account and share your sheet with its email
# Local: use the JSON file path below
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google-service-account.json
# Cloud (Render/Railway): paste entire JSON here instead of using a file
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
# Tab name inside the spreadsheet (default: Leads)
GOOGLE_SHEET_TAB=Leads

# OpenAI — improves understanding of spoken answers (optional but recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
